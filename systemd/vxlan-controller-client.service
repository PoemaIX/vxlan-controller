[Unit]
Description=VXLAN overlay client
Documentation=https://github.com/PoemaIX/vxlan-controller
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/vxlan-controller --mode client --config /etc/vxlan-controller/client.yaml
Restart=always
RestartSec=3
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
